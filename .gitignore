icarus/

# 操作系统
.DS_Store
Thumbs.db

# 排除整个 ip 目录（包括所有子文件）
**/ip/

# 忽略 UART.srcs/ 目录下的所有内容
UART.srcs/*
# 但保留 sim_1 和 sources_1 这两个文件夹（以及它们里面的内容）
!UART.srcs/sim_1/
!UART.srcs/sources_1/
!UART.srcs/constrs_1/

#忽略vscode配置文件
.vscode/